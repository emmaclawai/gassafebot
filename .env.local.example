# GasSafeBot Environment Variables
# Copy this file to .env.local and fill in your actual values

# Resend API Key for sending lead notification emails
# Get yours at https://resend.com
RESEND_API_KEY=re_your_resend_api_key_here

# Email address where lead notifications are sent
LEAD_EMAIL=hello@gassafebot.co.uk

# From email address for sending emails (must be verified in Resend)
FROM_EMAIL=audit@gassafebot.co.uk

# Optional: Send confirmation email to leads
SEND_CONFIRMATION=false
