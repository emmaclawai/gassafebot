# GasSafeBot Environment Variables
# Copy this file to .env.local and fill in your actual values

# Resend API Key for sending lead notification emails
# Get yours at https://resend.com
RESEND_API_KEY=re_your_resend_api_key_here

# Cloudflare Turnstile (bot protection)
# Get keys at https://dash.cloudflare.com → Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x00000000000000000000000000000000
TURNSTILE_SECRET_KEY=0x00000000000000000000000000000000

# Optional: Enable/disable Turnstile in development
# NEXT_PUBLIC_TURNSTILE_ENABLED=true
